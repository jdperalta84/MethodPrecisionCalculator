# Copy this file to .env and fill in your values before running the bot.
# Never commit your actual .env file to git.

# -----------------------------------------------------------------------
# Discord (required for Discord alerts)
# -----------------------------------------------------------------------
# How to get a webhook URL:
#   1. Open your Discord channel
#   2. Edit Channel -> Integrations -> Webhooks -> New Webhook
#   3. Copy the URL and paste it below
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------
# WhatsApp via Twilio (optional — leave blank to disable)
# -----------------------------------------------------------------------
# Sign up at https://www.twilio.com, enable the WhatsApp Sandbox,
# then copy your credentials here.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+1XXXXXXXXXX
